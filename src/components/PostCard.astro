---
import { estimateReadingTime, formatDate, resolveImagePath, slugFromId, slugify } from '@/lib/posts';

const { post, featured = false } = Astro.props;
const slug = slugFromId(post.id);
const image = resolveImagePath(post.data.heroImage ?? post.data.image);
const readingTime = estimateReadingTime(post.body ?? post.data.description);
const daysSincePublished =
  (Date.now() - post.data.pubDate.valueOf()) / (1000 * 60 * 60 * 24);
const isNew = daysSincePublished >= 0 && daysSincePublished <= 7;
---

<article class:list={['post-card', { featured }]}>
  <div class="post-card__titlebar">
    <span>{featured ? 'FEATURED.LOG' : 'BLOG_POST.HTML'}</span>
    {isNew && <span aria-hidden="true">NEW!</span>}
  </div>
  <a
    class="post-card__media"
    href={`/blog/${slug}/`}
    aria-label={`Read ${post.data.title}`}
    style={`--post-image: url('${image}')`}
  ></a>
  <div class="post-card__body">
    <div class="eyebrow">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    </div>
    <h2><a href={`/blog/${slug}/`}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <div class="post-card__meta-strip" aria-label="Post details">
      <span>{readingTime}</span>
    </div>
    <div class="tag-row" aria-label="Tags">
      {post.data.tags.map((tag) => <a href={`/tags/${slugify(tag)}/`}>#{tag}</a>)}
    </div>
  </div>
</article>
