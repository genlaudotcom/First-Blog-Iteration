---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact Gen Lau.">
  <section class="page-header">
    <p class="kicker">Contact.exe</p>
    <h1>Contact</h1>
    <p>Send notes, weird links, project ideas, or internet artifacts worth examining.</p>
  </section>

  <section class="contact-panel">
    <div class="retro-window">
      <div class="retro-window__bar">
        <span>message_box.html</span>
        <span>OK</span>
      </div>
      <div class="signal-panel">
        <span>Inbox status</span>
        <strong>Open to good weird</strong>
        <strong>creative experiments</strong>
        <strong>Codex projects</strong>
      </div>
    </div>

    <div class="contact-card">
      <p class="kicker">Reach me</p>
      <h2>Email</h2>
      <p>
        Drop a note at <a href="mailto:hello@genlau.com">hello@genlau.com</a>.
      </p>
    </div>
  </section>
</BaseLayout>
