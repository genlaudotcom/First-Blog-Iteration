---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact Gen Lau.">
  <section class="page-header">
    <p class="kicker">Contact.exe</p>
    <h1>Contact</h1>
    <p><strong>Reach out with questions, feelings, and most importantly, job offers &lt;3</strong></p>
  </section>

  <section class="contact-panel">
    <div class="retro-window contact-window">
      <div class="retro-window__bar">
        <span>message_box.html</span>
        <span>OK</span>
      </div>
      <div class="signal-panel">
        <span>Inbox status</span>
        <strong>Open to remote or hybrid in SF jobs</strong>
      </div>
    </div>

    <div class="contact-card">
      <p class="kicker">Reach me</p>
      <h2>Email</h2>
      <p>
        Drop a note at <a href="mailto:genevievekaryenlau@gmail.com">genevievekaryenlau@gmail.com</a>.
      </p>
      <h2>LinkedIn</h2>
      <p>
        <a href="https://linkedin.com/in/genevievekaryenlau">Peep my work history</a>.
      </p>
    </div>
  </section>
</BaseLayout>
