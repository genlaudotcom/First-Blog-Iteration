---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPublishedPosts, slugify } from '@/lib/posts';

const posts = await getPublishedPosts();
const categories = [...new Set(posts.map((post) => post.data.category))].sort();
---

<BaseLayout title="Blog" description="Creative experiments, essays, and weird Codex projects from genlau.com.">
  <section class="page-header">
    <p class="kicker">Archive</p>
    <h1>Blog</h1>
    <p>Creative experiments, essays, implementation notes, and odd little artifacts worth leaving on the open web.</p>
  </section>

  <section class="filters" aria-label="Categories">
    {categories.map((category) => <a href={`/categories/${slugify(category)}/`}>{category}</a>)}
  </section>

  <section class="post-list post-list--wide">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
