---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getFeaturedPosts, getPublishedPosts } from '@/lib/posts';
import profilePicture from '@/content/assets/profilepicture.JPG';

const featuredPosts = await getFeaturedPosts();
const latestPosts = (await getPublishedPosts()).slice(0, 4);
const heroPosts = featuredPosts.length > 0 ? featuredPosts : latestPosts.slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <div class="hero__copy">
      <p class="kicker">Loading website...</p>
      <h1>You want me to use AI? This is what you're going to get.</h1>
      <p>
        Tiny tools, durable essays, Codex side quests, and notes from a reformed tech worker
      </p>
      <div class="loading-widget" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span>
      </div>
      <div class="hero__actions">
        <a class="button" href="/blog/">Browse posts</a>
        <a class="button button--ghost" href="/contact/">Contact me</a>
      </div>
    </div>
    <div class="hero__visual">
      <div class="profile-stack">
        <figure class="profile-sticker">
          <img src={profilePicture.src} alt="Portrait of Gen Lau" width="839" height="839" />
          <figcaption>NEW PIC!</figcaption>
        </figure>
        <div class="retro-window">
        <div class="retro-window__bar">
          <span>status_window.gif</span>
          <span>OK</span>
        </div>
        <div class="signal-panel life-update">
          <span>life updates!</span>
          <strong>Also I'm unemployed and looking for a job</strong>
        </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="kicker">Featured</p>
      <h2>Good rabbit holes</h2>
    </div>
    <div class="featured-grid">
      {heroPosts.map((post) => <PostCard post={post} featured />)}
    </div>
  </section>

  <section class="section section--split">
    <div class="section-heading">
      <p class="kicker">Latest</p>
      <h2>Fresh artifacts</h2>
      <a href="/blog/">View all posts</a>
    </div>
    <div class="post-list">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
