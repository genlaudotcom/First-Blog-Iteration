---
import { SITE } from '@/data/site';
import favicon from '@/content/assets/favicon.png';
import genlauLogo from '@/content/assets/genlaulogoprint.png';
import '../styles/global.css';

const {
  title = SITE.title,
  description = SITE.description,
  image = favicon.src,
  type = 'website'
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url);
const pageTitle = title === SITE.title ? SITE.title : `${title} | ${SITE.title}`;
const imageUrl = new URL(image, SITE.url);
const isFaviconPreview = image === favicon.src;
const twitterCard = isFaviconPreview ? 'summary' : 'summary_large_image';
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8NGB33GVPC"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-8NGB33GVPC');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6c9f3" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={favicon.src} type="image/png" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    {isFaviconPreview && (
      <>
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content={favicon.width} />
        <meta property="og:image:height" content={favicon.height} />
        <meta property="og:image:alt" content={`${SITE.title} logo`} />
      </>
    )}
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={SITE.locale} />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__bar">
        <a class="brand" href={SITE.url} aria-label="Go to genlau.com">
          <img src={genlauLogo.src} alt="Gen Lau" width="930" height="284" />
        </a>
      </div>
      <div class="site-header__body">
        <p class="status-line">STATUS: <span>online</span></p>
        <nav aria-label="Primary navigation">
          {SITE.nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        &copy; {new Date().getFullYear()} {SITE.author}. Did I mention that I'm looking for a job?
      </p>
      <a href="/privacy/">Privacy</a>
    </footer>
  </body>
</html>
