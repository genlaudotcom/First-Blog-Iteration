---
import BaseLayout from './BaseLayout.astro';
import { formatDate, resolveImagePath, slugify } from '@/lib/posts';

const { post } = Astro.props;
const postUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://genlau.com').toString();
const shareUrl = encodeURIComponent(postUrl);
const heroImage = resolveImagePath(post.data.heroImage ?? post.data.image);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={heroImage}
  type="article"
>
  <article class="post-shell">
    <header class:list={['post-hero', { 'post-hero--solo': heroImage === '/social-card.svg' }]}>
      <div class="post-window">
        <div class="post-window__bar">
          <span>post_viewer.exe</span>
          <span aria-hidden="true">?</span>
        </div>
        <div class="post-window__body">
          <div class="eyebrow">
            <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          </div>
          <h1>{post.data.title}</h1>
          <p><strong>{post.data.description}</strong></p>
          <p class="post-ai-disclaimer">ironically contains AI generated images</p>
          <div class="tag-row">
            {post.data.tags.map((tag) => <a href={`/tags/${slugify(tag)}/`}>#{tag}</a>)}
          </div>
          <div class="share-row" aria-label="Share this post">
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}>Share on LinkedIn</a>
          </div>
        </div>
      </div>
      {heroImage !== '/social-card.svg' && (
        <figure class="post-hero__image">
          <img src={heroImage} alt="" loading="eager" decoding="async" />
        </figure>
      )}
    </header>
    <div class="post-grid">
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
