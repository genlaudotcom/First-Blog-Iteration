---
import BaseLayout from './BaseLayout.astro';
import { formatDate, resolveImagePath, slugify } from '@/lib/posts';

const { post, headings = [] } = Astro.props;
const postUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://genlau.com').toString();
const shareText = encodeURIComponent(`${post.data.title} by Gen Lau`);
const shareUrl = encodeURIComponent(postUrl);
const heroImage = resolveImagePath(post.data.heroImage ?? post.data.image);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={heroImage}
  type="article"
>
  <article class="post-shell">
    <header class="post-hero">
      <div class="eyebrow">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span>{post.data.category}</span>
      </div>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row">
        {post.data.tags.map((tag) => <a href={`/tags/${slugify(tag)}/`}>#{tag}</a>)}
      </div>
      <div class="share-row" aria-label="Share this post">
        <a href={`https://bsky.app/intent/compose?text=${shareText}%20${shareUrl}`}>Share</a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}>LinkedIn</a>
        <a href={`mailto:?subject=${shareText}&body=${shareUrl}`}>Email</a>
      </div>
      {heroImage !== '/social-card.svg' && (
        <figure class="post-hero__image">
          <img src={heroImage} alt="" loading="eager" decoding="async" />
        </figure>
      )}
    </header>
    <div class="post-grid">
      <aside class="toc" aria-label="Table of contents">
        <strong>Contents</strong>
        {headings.length > 0 ? (
          <nav>
            {headings.filter((heading) => heading.depth === 2).map((heading) => (
              <a href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </nav>
        ) : (
          <span>Short read</span>
        )}
      </aside>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
